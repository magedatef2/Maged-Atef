{
  "log": { "loglevel": "none" },
  "inbounds": [{
    "port": 80,
    "protocol": "vless",
    "settings": {
      "clients": [{"id": "97b69651-46c5-4d0f-8c3b-513689269432"}],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "ws",
      "wsSettings": { 
        "path": "/maged-net",
        "headers": { "Host": "magedatef-maged-server.hf.space" }
      }
    },
    "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
  }],
  "outbounds": [
    { 
      "protocol": "freedom", 
      "settings": { "domainStrategy": "UseIP" } 
    }
  ],
  "transport": {
    "mux": { 
      "enabled": true, 
      "concurrency": 16 
    }
  }
}
